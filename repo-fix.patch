+import asyncio
+import json
+from fastapi import FastAPI, WebSocket, WebSocketDisconnect
+import websockets
+
+app = FastAPI()
+
+HERMES_WS = "ws://localhost:5000/ws"  # user agent endpoint
+
+async def try_connect_hermes():
+    try:
+        ws = await websockets.connect(HERMES_WS)
+        return ws
+    except:
+        return None
+
+def parse_step(text: str):
+    t = (text or "").lower()
+
+    if "triangle" in t:
+        return {"visualType": "triangle_build"}
+
+    if "angle" in t:
+        return {
+            "visualType": "highlight_angles",
+            "data": {"angles": [60, 60, 60]}
+        }
+
+    if "180" in t or "180°" in t:
+        return {
+            "visualType": "show_result",
+            "data": {"text": "180°"}
+        }
+
+    return {
+        "visualType": "generic_text",
+        "data": {"text": text[:100]}
+    }
+
+@app.websocket("/ws")
+async def websocket_endpoint(client: WebSocket):
+    await client.accept()
+
+    try:
+        while True:
+            question = await client.receive_text()
+
+            hermes = await try_connect_hermes()
+
+            # CASE 1: REAL AGENT (streaming WS)
+            if hermes:
+                try:
+                    await hermes.send(question)
+                    async for msg in hermes:
+                        step = parse_step(msg)
+                        await client.send_text(json.dumps(step))
+                except Exception:
+                    # if streaming fails, fallback to mock below
+                    pass
+
+            # CASE 2: FALLBACK MOCK (or if agent not available)
+            mock_steps = [
+                {"visualType": "triangle_build"},
+                {"visualType": "highlight_angles"},
+                {"visualType": "show_result", "data": {"text": "180°"}}
+            ]
+
+            for step in mock_steps:
+                await client.send_text(json.dumps(step))
+                await asyncio.sleep(1.2)
+
+    except WebSocketDisconnect:
+        print("Client disconnected")
+
