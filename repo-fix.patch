+// src/agent/HermesSocketClient.js
+export function connectHermes(animationDirector){
+  const socket = new WebSocket("ws://localhost:8000/ws");
+
+  socket.addEventListener('open', () => {
+    console.log("[HermesSocket] connected to backend ws://localhost:8000/ws");
+  });
+
+  socket.addEventListener('message', (event) => {
+    try {
+      const step = JSON.parse(event.data);
+      if (animationDirector && typeof animationDirector.playStep === 'function') {
+        animationDirector.playStep(step);
+      } else {
+        // emit event for legacy handlers
+        window.dispatchEvent(new CustomEvent('hermes:step', { detail: step }));
+      }
+    } catch (e) {
+      console.warn('[HermesSocket] invalid message', e);
+    }
+  });
+
+  socket.addEventListener('close', () => {
+    console.log('[HermesSocket] closed');
+  });
+
+  socket.addEventListener('error', (err) => {
+    console.error('[HermesSocket] error', err);
+  });
+
+  return socket;
+}
+
