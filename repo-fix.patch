+class AnimationDirector {
+  constructor(sceneManager) {
+    // optional: accept a SceneManager instance (if present)
+    this.sceneManager = sceneManager || window.SceneManager || null;
+    this.activeObjects = [];
+  }
+
+  clearScene(){
+    if (this.sceneManager && typeof this.sceneManager.clearScene === 'function') {
+      this.sceneManager.clearScene();
+    } else {
+      // fallback: remove tracked activeObjects
+      this.activeObjects.forEach(o => {
+        try { if (o.parent) o.parent.remove(o); } catch(e) {}
+      });
+      this.activeObjects = [];
+    }
+  }
+
+  spawnTriangle(payload = {}) {
+    // delegate to SceneManager if available to keep rendering code in one place
+    if (this.sceneManager && typeof this.sceneManager.spawnTriangle === 'function') {
+      const tri = this.sceneManager.spawnTriangle(payload);
+      if (tri) this.activeObjects.push(tri);
+      return tri;
+    }
+    // fallback: emit event so SceneManager or main can listen
+    const ev = new CustomEvent('hermes:spawnTriangle', { detail: payload });
+    window.dispatchEvent(ev);
+  }
+
+  highlightAngles(data = {}) {
+    if (this.sceneManager && typeof this.sceneManager.highlightAngles === 'function') {
+      return this.sceneManager.highlightAngles(data);
+    }
+    const ev = new CustomEvent('hermes:highlightAngles', { detail: data });
+    window.dispatchEvent(ev);
+  }
+
+  showResult(text = '') {
+    if (this.sceneManager && typeof this.sceneManager.showResult === 'function') {
+      return this.sceneManager.showResult(text);
+    }
+    console.log('[AnimationDirector] showResult:', text);
+    const ev = new CustomEvent('hermes:showResult', { detail: { text }});
+    window.dispatchEvent(ev);
+  }
+
+  playStep(step) {
+    if (!step || !step.visualType) return;
+    // clear previous demo objects for idempotency
+    this.clearScene();
+
+    switch(step.visualType) {
+      case 'triangle_build':
+        this.spawnTriangle(step.data);
+        break;
+      case 'highlight_angles':
+        this.highlightAngles(step.data);
+        break;
+      case 'show_result':
+        this.showResult(step.data && step.data.text);
+        break;
+      case 'generic_text':
+        console.log('[AnimationDirector] generic_text:', step.data && step.data.text);
+        break;
+      default:
+        console.log('[AnimationDirector] unknown step:', step);
+    }
+  }
+}
+
+// expose globally (existing code expects window.animationDirector)
+if (!window.animationDirector) {
+  window.animationDirector = new AnimationDirector(window.sceneManager || null);
+}
+
+export default AnimationDirector;
+
